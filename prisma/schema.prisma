generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Room {
  id          Int      @id @default(autoincrement())
  roomNumber  String   @unique
  floor       Int
  monthlyRent Float
  status      String   @default("available")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant?
  bills       Bill[]
  applications Application[]
  @@map("rooms")
}

model Tenant {
  id         Int      @id @default(autoincrement())
  roomId     Int      @unique
  fullName   String
  phone      String
  idPhoto    String?
  moveInDate DateTime
  deposit    Float
  status     String   @default("active")
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  room       Room     @relation(fields: [roomId], references: [id])
  bills      Bill[]
  @@map("tenants")
}

model Application {
  id            Int      @id @default(autoincrement())
  roomId        Int?
  applicantName String
  phone         String
  notes         String?
  status        String   @default("new")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  room          Room?    @relation(fields: [roomId], references: [id])
  @@map("applications")
}

model Bill {
  id           Int       @id @default(autoincrement())
  tenantId     Int
  roomId       Int
  billingMonth String
  rentAmount   Float
  waterPrev    Float     @default(0)
  waterCurr    Float     @default(0)
  waterUnits   Float     @default(0)
  waterRate    Float     @default(0)
  waterAmount  Float     @default(0)
  elecPrev     Float     @default(0)
  elecCurr     Float     @default(0)
  elecUnits    Float     @default(0)
  elecRate     Float     @default(0)
  elecAmount   Float     @default(0)
  totalAmount  Float     @default(0)
  dueDate      DateTime
  status       String    @default("unpaid")
  paidDate     DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  room         Room      @relation(fields: [roomId], references: [id])
  @@unique([tenantId, billingMonth])
  @@map("bills")
}

model Setting {
  id           Int    @id @default(autoincrement())
  settingKey   String @unique
  settingValue String
  @@map("settings")
}
