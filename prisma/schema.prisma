generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Room {
  id           Int           @id @default(autoincrement())
  roomNumber   String        @unique
  floor        Int
  monthlyRent  Float
  status       String        @default("available") // available | occupied | maintenance
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant       Tenant?
  bills        Bill[]
  applications Application[]

  @@index([status])
  @@index([floor, roomNumber])
  @@map("rooms")
}

model Tenant {
  id         Int       @id @default(autoincrement())
  roomId     Int?      @unique
  fullName   String
  phone      String
  idPhoto    String?
  moveInDate DateTime
  deposit    Float
  status     String    @default("active") // active | moved_out
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  room       Room?     @relation(fields: [roomId], references: [id])
  bills      Bill[]

  @@index([status])
  @@index([fullName])
  @@map("tenants")
}

model Application {
  id            Int      @id @default(autoincrement())
  roomId        Int?
  applicantName String
  phone         String
  notes         String?
  status        String   @default("new") // new | approved | rejected | waitlisted | moved_in
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  room          Room?    @relation(fields: [roomId], references: [id])

  @@index([status, createdAt])
  @@index([roomId])
  @@map("applications")
}

model Bill {
  id           Int       @id @default(autoincrement())
  tenantId     Int
  roomId       Int
  billingMonth String
  rentAmount   Float
  waterPrev    Float     @default(0)
  waterCurr    Float     @default(0)
  waterUnits   Float     @default(0)
  waterRate    Float     @default(0)
  waterAmount  Float     @default(0)
  elecPrev     Float     @default(0)
  elecCurr     Float     @default(0)
  elecUnits    Float     @default(0)
  elecRate     Float     @default(0)
  elecAmount   Float     @default(0)
  totalAmount  Float     @default(0)
  dueDate      DateTime
  status       String    @default("unpaid") // unpaid | paid
  paidDate     DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  room         Room      @relation(fields: [roomId], references: [id])

  @@unique([tenantId, billingMonth])
  @@index([billingMonth])
  @@index([billingMonth, status])
  @@index([roomId, billingMonth])
  @@index([status])
  @@map("bills")
}

model Setting {
  id           Int    @id @default(autoincrement())
  settingKey   String @unique
  settingValue String

  @@map("settings")
}
